def main():
    print("="*60)
    print("سیستم بهینه‌سازی ساختمان با هوش مصنوعی و الگوریتم کوانتومی")
    print("(بدون هیچ کتابخانه خارجی)")
    print("="*60)

    # 1. ایجاد مدل BIM ساختگی (مثلاً یک ساختمان نمونه از Revit)
    bim = BIMModel()
    bim.add_room(BIMRoom("اتاق نشیمن", 30, 5.0, 0.5, 2))   # جنوب
    bim.add_room(BIMRoom("خواب ۱", 20, 2.5, 0.4, 0))       # شمال
    bim.add_room(BIMRoom("آشپزخانه", 15, 1.5, 0.6, 3))     # غرب
    print("مدل BIM بارگذاری شد (شبیه‌سازی Revit).")

    # 2. آموزش شبکه عصبی روی داده‌های شبیه‌سازی‌شده انرژی
    print("در حال ساخت و آموزش شبکه عصبی پیش‌بین مصرف انرژی...")
    X, Y = generate_dataset(200)
    nn = NeuralNetwork([4, 8, 1])  # 4 ورودی (area, window_area, uvalue, orientation) -> 1 خروجی انرژی
    nn.train(X, Y, epochs=200, lr=0.01)
    print("شبکه عصبی آموزش دید.")

    # 3. راه‌اندازی مدار کوانتومی پارامتری
    n_qubits = 2
    n_params = 4  # تعداد پارامترهای RY
    vqc = VQC(n_qubits, n_params)
    print(f"مدار کوانتومی با {n_qubits} کیوبیت و {n_params} پارامتر آماده شد.")

    # 4. بهینه‌سازی هیبریدی
    print("\nشروع بهینه‌سازی با مدار کوانتومی (VQC)...")
    hybrid = HybridOptimizer(nn, vqc, bim)
    initial_design = [0.3, 0.5]  # start point window ratio, u-value
    best_design, best_cost = hybrid.optimize_with_vqc(initial_design, steps=30, lr=0.1)

    print("\n" + "="*60)
    print("نتیجه بهینه‌سازی:")
    print(f"نسبت بهینه سطح پنجره (WWR): {best_design[0]:.3f}")
    print(f"مقدار بهینه U-Value دیوار: {best_design[1]:.3f} W/m²K")
    print(f"هزینه نهایی (مصرف انرژی + جریمه): {best_cost:.2f}")
    print("="*60)
    print("آماده برای اعمال این پارامترها در مدل Revit (از طریق API یا Dynamo).")

if __name__ == "__main__":
    main()
